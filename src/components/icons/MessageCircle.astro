---
interface Props {
  size?: number;
  class?: string;
}
const { size = 24, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
>
  <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
</svg>
