---
interface Props {
  text: string;
  href?: string;
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit";
  class?: string;
  id?: string;
}

const {
  text,
  href,
  size = "md",
  type = "button",
  class: className = "",
  id,
} = Astro.props;

const Tag = href ? "a" : "button";
---

<Tag
  href={href || undefined}
  type={!href ? type : undefined}
  class={`icon-button-wrapper ${className}`}
  id={id}
>
  <div class={`icon-button-3d icon-button-${size}`}>
    <!-- Rectángulo inferior (base/sombra) -->
    <div class="icon-button-bottom"></div>

    <!-- Rectángulo superior (contenido) -->
    <div class="icon-button-top">
      <span class="icon-button-icon">
        <slot />
      </span>
      <span class="icon-button-text">{text}</span>
    </div>
  </div>
</Tag>

<style>
  .icon-button-wrapper {
    display: inline-block;
    text-decoration: none;
    cursor: pointer;
    border: none;
    background: none;
    padding: 0;
    font-family: inherit;
  }

  .icon-button-3d {
    position: relative;
    display: inline-block;
    padding-bottom: 8px;
  }

  /* Rectángulo inferior - sombra 3D */
  .icon-button-bottom {
    position: absolute;
    bottom: 0;
    left: -6px;
    right: -6px;
    height: 8px;
    background: #eeeff3;
    border-radius: 16px;
    transition: height 0.15s ease;
  }

  /* Rectángulo superior */
  .icon-button-top {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #fefefe;
    border-radius: 16px;
    font-family:
      "DM Sans",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-weight: 500;
    color: #1d1d1f;
    border: 1px solid rgba(0, 0, 0, 0.08);
    white-space: nowrap;
    top: 0;
    transition: top 0.15s ease;
  }

  .icon-button-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-button-text {
    flex-shrink: 0;
  }

  /* Tamaño pequeño */
  .icon-button-sm {
    padding-bottom: 6px;
  }

  .icon-button-sm .icon-button-top {
    padding: 0.4rem 0.8rem;
    font-size: 0.8rem;
    gap: 0.35rem;
  }

  .icon-button-sm .icon-button-bottom {
    height: 56px;
  }

  /* Tamaño mediano */
  .icon-button-md {
    padding-bottom: 10px;
  }

  .icon-button-md .icon-button-top {
    padding: 0.6rem 1.25rem;
    font-size: 0.95rem;
  }

  .icon-button-md .icon-button-bottom {
    height: 56px;
  }

  /* Tamaño grande */
  .icon-button-lg {
    padding-bottom: 12px;
  }

  .icon-button-lg .icon-button-top {
    padding: 0.85rem 1.75rem;
    font-size: 1.05rem;
  }

  .icon-button-lg .icon-button-bottom {
    height: 56px;
  }

  /* Hover */
  .icon-button-wrapper:hover .icon-button-top {
    background: #fafafa;
  }

  /* Active/Click — efecto presionar tecla */
  .icon-button-wrapper:active .icon-button-top {
    top: 4px;
  }

  .icon-button-wrapper:active .icon-button-bottom {
    height: 4px;
  }
</style>
