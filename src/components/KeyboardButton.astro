---
interface Props {
  variant?: "white" | "blue";
  customColor?: string;
  href?: string;
  target?: string;
  class?: string;
  type?: "button" | "submit";
}

const {
  variant = "white",
  customColor,
  href,
  target,
  class: className = "",
  type = "button",
} = Astro.props;

// Predefined color schemes
const variants = {
  white: {
    base: "linear-gradient(180deg, #F8F9FA 0%, #E9ECEF 100%)",
    hover: "linear-gradient(180deg, #E9ECEF 0%, #DEE2E6 100%)",
    text: "#1d1d1f",
    shadow: "#D1D5DB",
  },
  blue: {
    base: "linear-gradient(180deg, #3B82F6 0%, #2563EB 100%)",
    hover: "linear-gradient(180deg, #2563EB 0%, #1D4ED8 100%)",
    text: "#FFFFFF",
    shadow: "#1E40AF",
  },
};

const colors = customColor ? null : variants[variant];
---

{
  href ? (
    <a
      href={href}
      target={target}
      class={`keyboard-btn ${variant} ${className}`}
      style={
        customColor
          ? `--custom-color: ${customColor}; --custom-text: ${variant === "blue" ? "#FFFFFF" : "#1d1d1f"};`
          : ""
      }
    >
      <slot />
    </a>
  ) : (
    <button
      type={type}
      class={`keyboard-btn ${variant} ${className}`}
      style={
        customColor
          ? `--custom-color: ${customColor}; --custom-text: ${variant === "blue" ? "#FFFFFF" : "#1d1d1f"};`
          : ""
      }
    >
      <slot />
    </button>
  )
}

<style>
  .keyboard-btn {
    /* Base styles */
    display: inline-block;
    padding: 0.875rem 2rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.05rem;
    transition: all 0.15s ease;
    border: 1px solid rgba(0, 0, 0, 0.1);
    cursor: pointer;
    position: relative;
    top: 0;
    text-align: center;
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu,
      sans-serif;
  }

  /* White variant */
  .keyboard-btn.white {
    background: #ffffff;
    color: #1d1d1f;
    border: 1px solid #e5e7eb;
    box-shadow:
      0 1px 0 0 rgba(255, 255, 255, 0.9) inset,
      0 4px 0 0 #d1d5db,
      0 5px 2px 0 rgba(0, 0, 0, 0.15);
  }

  .keyboard-btn.white:hover {
    background: #f3f4f6;
    transform: translateY(2px);
    box-shadow:
      0 1px 0 0 rgba(255, 255, 255, 0.7) inset,
      0 2px 0 0 #d1d5db,
      0 3px 1px 0 rgba(0, 0, 0, 0.1);
  }

  .keyboard-btn.white:active {
    transform: translateY(4px);
    box-shadow:
      0 1px 0 0 rgba(255, 255, 255, 0.5) inset,
      0 0px 0 0 #d1d5db,
      0 1px 0 0 rgba(0, 0, 0, 0.05);
  }

  /* Blue variant */
  .keyboard-btn.blue {
    background: #01579b;
    color: #ffffff;
    border: 1px solid #013d6b;
    box-shadow:
      0 1px 0 0 rgba(255, 255, 255, 0.15) inset,
      0 4px 0 0 #013d6b,
      0 5px 2px 0 rgba(0, 0, 0, 0.25);
  }

  .keyboard-btn.blue:hover {
    background: #014b87;
    transform: translateY(2px);
    box-shadow:
      0 1px 0 0 rgba(255, 255, 255, 0.1) inset,
      0 2px 0 0 #013d6b,
      0 3px 1px 0 rgba(0, 0, 0, 0.2);
  }

  .keyboard-btn.blue:active {
    transform: translateY(4px);
    box-shadow:
      0 1px 0 0 rgba(255, 255, 255, 0.08) inset,
      0 0px 0 0 #013d6b,
      0 1px 0 0 rgba(0, 0, 0, 0.15);
  }

  /* Responsive sizing */
  @media (max-width: 768px) {
    .keyboard-btn {
      padding: 0.75rem 1.5rem;
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .keyboard-btn {
      padding: 0.625rem 1.25rem;
      font-size: 0.95rem;
    }
  }
</style>
