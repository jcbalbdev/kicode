---
// Hero simplificado para kicode
---

<section class="hero">
  <div class="hero-container">
    <!-- Headline con efecto tachado -->
    <h1 class="hero-headline">
      Tu negocio <span class="word-wrapper">
        <span class="strikethrough">está</span>
        <span class="handwritten">estaba</span>
      </span>
      <br />
      fuera de control
