---
const { icon, title, description } = Astro.props;
---

<div class="feature-card">
  <div class="feature-icon">{icon}</div>
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .feature-card {
    background: white;
    padding: 2rem;
    border-radius: 24px;
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
  }

  .feature-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: #1d1d1f;
  }

  .feature-card p {
    color: #6e6e73;
    line-height: 1.6;
  }
</style>
