---
const { question, answer } = Astro.props;
---

<details class="faq-item">
  <summary>{question}</summary>
  <p>{answer}</p>
</details>

<style>
  .faq-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 5.35s ease;
  }

  .faq-item[open] .faq-content {
    max-height: 200px;
  }
.faq-item {
    background: #f5f5f7;
    border-radius: 16px;
    margin-bottom: 1rem;
    padding: 1.5rem 2rem;
    cursor: pointer;
  }

  .faq-item summary {
    font-size: 1.25rem;
    font-weight: 600;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #1d1d1f;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    font-size: 1.5rem;
    transition: transform 0.5s;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }
.faq-item[open] {
  background: white;
  box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    transition: all 0.8s ease;

}
  .faq-item p {
    margin-top: 1rem;
    color: #6e6e73;
    line-height: 1.8;
  }
</style>
