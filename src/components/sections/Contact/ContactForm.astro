---
import Button from "../../ui/Button.astro";
---

<form class="contact-form">
  <h3>Solicita tu demo</h3>
  <input type="text" placeholder="Nombre completo" required />
  <input type="email" placeholder="Email" required />
  <input type="tel" placeholder="WhatsApp" required />
  <select required>
    <option value="">Tipo de negocio</option>
    <option>Salón de belleza / Barbershop</option>
    <option>Consultorio médico / Dental</option>
    <option>Taller mecánico</option>
    <option>Coach / Consultor</option>
    <option>Otro</option>
  </select>
  <textarea placeholder="Cuéntanos sobre tu negocio (opcional)" rows="4"
  ></textarea>
  <Button text="Agendar Demo Gratis" targetId="#" size="md" />
</form>

<style>
  .contact-form {
    background: white;
    padding: var(--spacing-md);
    border-radius: 24px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  .contact-form h3 {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-md);
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    padding: 0.875rem;
    border: 2px solid var(--color-border);
    border-radius: 12px;
    font-size: 1rem;
    margin-bottom: var(--spacing-sm);
    font-family: var(--font-sans);
    transition: border-color 0.3s;
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }
</style>
