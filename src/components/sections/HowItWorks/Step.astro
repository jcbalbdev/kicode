---
interface Props {
  number: number;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="step">
  <div class="step-number">{number}</div>
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .step {
    flex: 1;
    min-width: 200px;
    text-align: center;
  }

  .step-number {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--gradient-blue);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 auto var(--spacing-sm);
  }

  .step h3 {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-xs);
  }
</style>
