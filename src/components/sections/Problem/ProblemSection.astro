---
import ProblemCard from "./ProblemCard.astro";
---

<section class="problem">
  <div class="container">
    <h2 class="section-title">¿Te suena familiar?</h2>
    <div class="grid-4">
      <ProblemCard
        image="/tarjeta1.png"
        icon="📱"
        title="Pierdes clientes"
        description="No respondes WhatsApp a tiempo perdiendo clientes"
        solution="Un bot de WhatsApp responde automáticamente en segundos, 24/7, sin que tengas que estar pendiente del celular."
      />
      <ProblemCard
        image="/tarjeta2.png"
        icon="📱"
        title="Tu agenda es un caos"
        description="Tienes citas sin confirmar y clientes que no aparecen"
        solution="Un bot de WhatsApp responde automáticamente en segundos, 24/7, sin que tengas que estar pendiente del celular."
      />
      <ProblemCard
        image="/tarjeta3.png"
        icon="📱"
        title="Haces todo manual"
        description="Copias datos de un lado a otro perdiendo productividad diaria"
        solution="Un bot de WhatsApp responde automáticamente en segundos, 24/7, sin que tengas que estar pendiente del celular."
      />
      <ProblemCard
        image="/tarjeta4.png"
        icon="📱"
        title="Sin control del negocio"
        description="No tienes reportes ni métricas claras, avanzas sin rumbo"
        solution="Un bot de WhatsApp responde automáticamente en segundos, 24/7, sin que tengas que estar pendiente del celular."
      />
    </div>
  </div>
</section>

<style>
  .problem {
    background: radial-gradient(
      circle at 43% 43%,
      #eff6ff 0%,
      #ffffff 40%,
      #fffbeb 100%
    );
  }
</style>
