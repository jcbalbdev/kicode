---
import ProblemCard from "./ProblemCard.astro";
---

<section class="problem">
  <div class="container">
    <h2 class="section-title">¿Te suena familiar?</h2>
    <div class="grid-4">
      <ProblemCard
        image="/tarjeta1.png"
        icon="📱"
        title="Pierdes clientes"
        description="No respondes WhatsApp a tiempo perdiendo clientes"
        solution="Bot de WhatsApp que responde automáticamente en segundos, los 365 día del año, capturando leads y programando seguimientos sin intervención manual."
        variant="clients"
      />
      <ProblemCard
        image="/tarjeta2.png"
        icon="📱"
        title="Tu agenda es un caos"
        description="Tienes citas sin confirmar y clientes que no aparecen"
        solution="Calendario inteligente con confirmaciones automáticas, recordatorios por medio de WhatsApp y sincronización con Google Calendar para estar al tanto de absolutamente todo."
        variant="agenda"
      />
      <ProblemCard
        image="/tarjeta3.png"
        icon="📱"
        title="Haces todo manual"
        description="Copias datos de un lado a otro perdiendo productividad diaria"
        solution="Automatización de procesos con integración entre WhatsApp, CRM y tu calendario para eliminar copia de datos y tareas repetitivas innecesarias."
        variant="manual"
      />
      <ProblemCard
        image="/tarjeta4.png"
        icon="📱"
        title="Sin control del negocio"
        description="No tienes reportes ni métricas claras, avanzas sin rumbo"
        solution="Dashboard con métricas clave en tiempo real: conversación, conversiones, ingresos y KPI's personalizables para decisiones basadas en tus datos obtenidos de forma automática."
        variant="control"
      />
    </div>
  </div>
</section>

<style>
  .problem {
    background: radial-gradient(
      circle at 43% 43%,
      #eff6ff 0%,
      #ffffff 40%,
      #fffbeb 100%
    );
  }
</style>
