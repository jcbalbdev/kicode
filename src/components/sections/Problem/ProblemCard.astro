---
const { icon, title, description, solution, image } = Astro.props;
---

<div class="flip-card">
  <div class="flip-inner">
    <!-- Frente: el dolor -->
    <div class={`flip-front ${image ? "has-image" : ""}`}>
      {
        image ? (
          <img src={image} alt={title} class="card-image" />
        ) : (
          <>
            <div class="icon">{icon}</div>
            <h3>{title}</h3>
            <p>{description}</p>
            <span class="hint">Pasa el mouse →</span>
          </>
        )
      }
    </div>

    <!-- Reverso: la solución de Kicode -->
    <div class="flip-back">
      <div class="solution-badge">✦ Solución Kicode</div>
      <p class="solution-text">{solution}</p>
    </div>
  </div>
</div>

<style>
  .flip-card {
    perspective: 1000px;
    width: 100%;
    aspect-ratio: 9 / 16;
  }

  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  .flip-card:hover .flip-inner {
    transform: rotateY(180deg);
  }

  .flip-front,
  .flip-back {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    padding: 2rem;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .flip-front {
    background: white;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
    padding: 2rem;
  }

  .flip-front.has-image {
    padding: 0;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .flip-front h3 {
    font-size: 1.35rem;
    font-weight: 700;
    color: #1d1d1f;
    margin-bottom: 0.5rem;
  }

  .flip-front p {
    color: #6e6e73;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .hint {
    margin-top: 1.25rem;
    font-size: 0.75rem;
    color: #c0c0c8;
    letter-spacing: 0.03em;
  }

  .flip-back {
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
    transform: rotateY(180deg);
    gap: 1rem;
  }

  .solution-badge {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
  }

  .solution-text {
    color: white;
    font-size: 1.05rem;
    line-height: 1.65;
    font-weight: 500;
  }
</style>
