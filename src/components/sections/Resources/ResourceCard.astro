---
const { icon, title, description, tag, href = "#" } = Astro.props;
---

<a href={href} class="resource-card">
  <div class="resource-icon">{icon}</div>
  <h3>{title}</h3>
  <p>{description}</p>
  <span class="resource-tag">{tag}</span>
</a>

<style>
  .resource-card {
    background: white;
    padding: 2rem;
    border-radius: 24px;
    text-decoration: none;
    color: #1d1d1f;
    transition: all 0.3s ease;
    position: relative;
    display: block;
  }

  .resource-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
  }

  .resource-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .resource-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .resource-card p {
    color: #6e6e73;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .resource-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: linear-gradient(135deg, #2563eb 0%, #60a5fa 100%);
    color: white;
    border-radius: 12px;
    font-size: 0.875rem;
    font-weight: 600;
  }
</style>
